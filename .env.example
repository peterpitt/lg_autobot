# ============================================================
# susucloud 優惠機票訂閱系統 — 環境變數範本
# 把這個檔案複製成 .env.local 後填入真實金鑰
#   cp .env.example .env.local
# ============================================================

# --- 網站網址（本機開發用 localhost，正式環境用你的網域）---
NEXT_PUBLIC_SITE_URL=https://susucloud.site

# --- Supabase（資料庫 + 登入）---
# Supabase 後台 > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# service_role 金鑰：只在伺服器端用（cron 寫資料），絕不可外洩
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# --- Stripe（海外訂閱金流）---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Stripe 後台建立的「Pro 方案」價格 ID（每月訂閱）
STRIPE_PRICE_PRO=price_xxx

# --- Travelpayouts / Aviasales（查機票價格）---
# https://www.travelpayouts.com  申請後在後台拿 API token
TRAVELPAYOUTS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 你的聯盟行銷 marker（之後導購可抽成，可先留空）
TRAVELPAYOUTS_MARKER=

# --- Resend（寄送通知 email）---
# https://resend.com  申請後拿 API key，並驗證寄件網域
RESEND_API_KEY=re_xxx
EMAIL_FROM=優惠機票通知 <alerts@susucloud.site>

# --- Cron 安全金鑰（自己設一組長亂碼，Vercel Cron 會用它呼叫）---
CRON_SECRET=請改成一段很長的隨機字串
